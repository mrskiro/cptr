{
  "name": "@cptr/extension",
  "version": "0.0.0",
  "private": true,
  "description": "Arc-like element screenshot for Chrome",
  "type": "module",
  "scripts": {
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "check-types": "tsc --noEmit",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "postinstall": "wxt prepare",
    "test": "vitest run",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.2.1",
    "lucide-preact": "0.575.0",
    "preact": "10.28.4",
    "tailwindcss": "4.2.1"
  },
  "devDependencies": {
    "@vitest/browser-playwright": "4.0.18",
    "typescript": "^5.9.3",
    "vitest": "4.0.18",
    "vitest-browser-preact": "1.0.0",
    "wxt": "^0.20.18"
  }
}
